// Prisma schema for Fashion Enthusiasts forum
// Designed for Neon PostgreSQL — Discussion only

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Users ───────────────────────────────────────────────────
model User {
  id        String   @id @default(cuid())
  username  String   @unique
  avatar    String?
  createdAt DateTime @default(now()) @map("created_at")

  threads Thread[]
  posts   Post[]

  @@map("users")
}

// ─── Categories / Subforums ──────────────────────────────────
model Category {
  id          String         @id @default(cuid())
  name        String         @unique
  slug        String         @unique
  description String?
  icon        String?
  sortOrder   Int            @default(0) @map("sort_order")
  status      CategoryStatus @default(DISABLED)
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  threads Thread[]

  @@map("categories")
}

enum CategoryStatus {
  ACTIVE
  DISABLED
  COMING_SOON
  ARCHIVED
}

// ─── Threads ─────────────────────────────────────────────────
model Thread {
  id        String   @id @default(cuid())
  commentId String   @unique @map("comment_id")
  title     String
  slug      String   @unique
  content   String
  models    String[] @default([])
  views     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  authorId   String   @map("author_id")
  author     User     @relation(fields: [authorId], references: [id])
  categoryId String   @map("category_id")
  category   Category @relation(fields: [categoryId], references: [id])

  posts Post[]

  @@index([categoryId])
  @@index([authorId])
  @@index([createdAt])
  @@map("threads")
}

// ─── Posts (replies, nested) ─────────────────────────────────
model Post {
  id        String   @id @default(cuid())
  commentId String   @unique @map("comment_id")
  content   String
  models    String[] @default([])
  depth     Int      @default(2)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  authorId String @map("author_id")
  author   User   @relation(fields: [authorId], references: [id])
  threadId String @map("thread_id")
  thread   Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  parentId String? @map("parent_id")
  parent   Post?   @relation("PostReplies", fields: [parentId], references: [id])
  replies  Post[]  @relation("PostReplies")

  @@index([threadId])
  @@index([parentId])
  @@index([authorId])
  @@index([createdAt])
  @@map("posts")
}

// ─── Scheduled Comments (queue for cron job) ─────────────────
model ScheduledComment {
  id            String   @id @default(cuid())
  commentId     String   @unique @map("comment_id")
  dayNumber     Int      @map("day_number")
  publishOrder  Int      @map("publish_order")
  publishDate   DateTime @map("publish_date")
  type          String   // "thread" or "reply"
  threadRootId  String   @map("thread_root_id")
  parentId      String?  @map("parent_comment_id")
  depth         Int      @default(1)
  username      String
  personaTag    String?  @map("persona_tag")
  intent        String?
  sentiment     String?
  models        String[] @default([])
  title         String?
  body          String
  published     Boolean  @default(false)
  publishedAt   DateTime? @map("published_at")

  @@index([publishDate, published])
  @@index([dayNumber])
  @@index([threadRootId])
  @@map("scheduled_comments")
}
